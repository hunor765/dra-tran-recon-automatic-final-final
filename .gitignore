# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep example template, ignore real secrets
.env
.env.local
.env.*.local
backend/.env

# vercel
.vercel

# SSH keys and credentials
dra-tran-recon-auto-ssh-key
dra-tran-recon-auto-ssh-key.pub
*_rsa
*_ed25519
*.key

# PDF reports (generated artifacts)
*.pdf

# Python
backend/venv/
backend/__pycache__/
backend/app/**/__pycache__/
**/*.pyc
**/*.pyo
.pytest_cache/

# typescript
*.tsbuildinfo
next-env.d.ts
