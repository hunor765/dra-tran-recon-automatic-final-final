# Copy this file to .env and fill in values

# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://dra:yourpassword@localhost:5432/dra_saas

# JWT — generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-generate-real-jwt-secret

# Fernet encryption key for API credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-real-fernet-key

# CORS — comma-separated list of allowed origins in production
# e.g. https://app.yourdomain.com
ALLOWED_ORIGINS=["http://localhost:3000"]

# App environment: development | production
APP_ENV=development
