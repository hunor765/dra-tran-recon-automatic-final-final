# Root .env — used by docker-compose.yml
# Copy to .env and fill in real values before running docker compose up

# PostgreSQL password (used by both db service and api DATABASE_URL)
POSTGRES_PASSWORD=b4ecf40f38d214da6821401b

# JWT signing secret (must match backend JWT_SECRET)
# Generate: openssl rand -hex 32
JWT_SECRET=869db62fb3c2b644532b7c2110f34be68c187e1a0d28e365652043b7e868914b

# Fernet key for encrypting API credentials at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=cNWHsTE6wxWpIxInw1JE5JS3V3iNpOCZbkI8ucYu9GYg=

# Allowed CORS origins (JSON list, must include frontend URL)
ALLOWED_ORIGINS=["https://dra-tran-recon.splitagency.eu"]

# Your domain (used by nginx for SSL certificate paths)
DOMAIN=dra-tran-recon.splitagency.eu
